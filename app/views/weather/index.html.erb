<div class="grid grid-cols-1 gap-6 md:grid-cols-12 md:gap-8">
  <% if logged_in? %>
    <section class="glass col-span-1 p-8 md:col-span-12 md:p-12">
      <h1 class="mb-2 text-2xl font-bold tracking-tight text-white md:text-4xl">
        Consulte o clima da sua cidade
      </h1>
      <p class="mb-8 text-slate-400">Busca em tempo real com dados meteorológicos atualizados.</p>

      <form id="clima-form" class="flex flex-col gap-4 sm:flex-row" data-turbo="false">
        <input
          type="text"
          id="cidade"
          name="cidade"
          class="input-field flex-1"
          placeholder="Digite uma cidade..."
          autocomplete="address-level2"
        />
        <button type="submit" class="btn-primary w-full shrink-0 sm:w-auto">
          Buscar
        </button>
      </form>
    </section>

    <div
      id="resultado"
      class="col-span-1 min-h-[280px] md:col-span-12"
      aria-live="polite"
    ></div>
  <% else %>
    <section class="glass col-span-1 mx-auto w-full max-w-lg py-16 text-center md:col-span-12 lg:col-start-3 lg:col-span-8">
      <h2 class="mb-4 text-3xl font-bold text-white">Bem-vindo</h2>
      <p class="mb-8 text-lg leading-relaxed text-slate-400">
        Faça login para consultar o clima em tempo real.
      </p>
      <%= link_to "Entrar", login_path, class: "btn-primary" %>
    </section>
  <% end %>
</div>
