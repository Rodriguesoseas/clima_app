<div class="flex min-h-[calc(100vh-8rem)] items-center justify-center py-8">
  <div class="glass w-full max-w-md p-8">
    <h1 class="mb-6 text-2xl font-bold text-white">Entrar</h1>

    <% if flash[:alert] %>
      <p class="error-box mb-6"><%= flash[:alert] %></p>
    <% end %>

    <%= form_with url: login_path, method: :post, class: "flex flex-col gap-4" do %>
      <div>
        <%= label_tag :email, "E-mail", class: "mb-2 block text-sm font-medium text-slate-300" %>
        <%= email_field_tag :email, params[:email], class: "input-field", autocomplete: "username", required: true %>
      </div>

      <div>
        <%= label_tag :password, "Senha", class: "mb-2 block text-sm font-medium text-slate-300" %>
        <%= password_field_tag :password, nil, class: "input-field", autocomplete: "current-password", required: true %>
      </div>

      <%= submit_tag "Entrar", class: "btn-primary mt-2 w-full cursor-pointer" %>
    <% end %>

    <p class="mt-6 text-center text-sm text-slate-400">
      <%= link_to "Voltar ao início", root_path, class: "text-blue-400 transition hover:text-blue-300 hover:underline" %>
    </p>

    <p class="mt-2 text-center text-sm text-slate-400">
      Não tem conta?
      <%= link_to "Cadastrar", signup_path, class: "text-blue-400 transition hover:text-blue-300 hover:underline" %>
    </p>
  </div>
</div>
